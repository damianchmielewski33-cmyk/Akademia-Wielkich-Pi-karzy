# W produkcji ustaw silny sekret (min. 32 znaki). Bez tego aplikacja nie wystartuje.
AUTH_SECRET=

# Opcjonalnie: ścieżka do pliku SQLite względem katalogu projektu
# DATABASE_PATH=data/database.db

# Produkcja (Vercel / serverless): zdalna baza libSQL (Turso). Bez tego każda instancja ma osobny /tmp — dane nie są współdzielone.
# Lokalnie zwykle puste: wtedy używany jest plik SQLite powyżej.
# Utwórz bazę w https://turso.tech , skopiuj URL oraz token do zmiennych w Vercel → Environment Variables i wdróż ponownie.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Jednorazowo po utworzeniu pustej bazy w Turso (tworzy tabele): npm run db:init-turso

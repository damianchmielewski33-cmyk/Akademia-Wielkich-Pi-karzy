# Publiczny adres strony (https://…), bez końcowego „/”. Kanoniczne URL-e, sitemap i robots dla Google.
NEXT_PUBLIC_SITE_URL=

# W produkcji ustaw silny sekret (min. 32 znaki). Bez tego aplikacja nie wystartuje.
AUTH_SECRET=

# Opcjonalnie: ścieżka do pliku SQLite względem katalogu projektu
# DATABASE_PATH=data/database.db

# Produkcja (Vercel / serverless): zdalna baza libSQL (Turso). Bez tego każda instancja ma osobny /tmp — dane nie są współdzielone.
# Lokalnie zwykle puste: wtedy używany jest plik SQLite powyżej.
# Utwórz bazę w https://turso.tech , skopiuj URL oraz token do zmiennych w Vercel → Environment Variables i wdróż ponownie.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Jednorazowo po utworzeniu pustej bazy w Turso (tworzy tabele): npm run db:init-turso

# Opcjonalnie: prognoza w terminarzu z Google Weather (10 dni). Ten sam klucz: Geocoding API + Weather API w Google Cloud.
# Bez klucza aplikacja używa darmowego Open-Meteo (nadaje się do testów; do produkcji rozważ klucz Google).
# Alternatywne nazwy zmiennej (jeśli używasz innej konwencji): GOOGLE_CLOUD_MAPS_API_KEY, MAPS_PLATFORM_SERVER_KEY
GOOGLE_MAPS_API_KEY=
# GOOGLE_CLOUD_MAPS_API_KEY=
# MAPS_PLATFORM_SERVER_KEY=

# Opcjonalnie: własny User-Agent do geokodowania Nominatim (OpenStreetMap), gdy domyślny jest odrzucany.
# NOMINATIM_USER_AGENT=
